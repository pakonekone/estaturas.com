---
import Base from '../layouts/Base.astro';
import Comparador from '../components/Comparador';
import famososData from '../data/famosos.json';
import { cmToFtIn, PROMEDIO_H, PROMEDIO_M, MIN_HUMAN_H, MAX_HUMAN_H } from '../utils/height';
import comparacionesData from '../data/top-comparaciones.json';
import rankingsData from '../data/rankings.json';

export function getStaticPaths() {
  return famososData.map(f => ({ params: { famoso: f.id }, props: { famoso: f } }));
}

const { famoso } = Astro.props;

const MIN_H = MIN_HUMAN_H, MAX_H = MAX_HUMAN_H;
const barPct = Math.round(((famoso.estaturaCm - MIN_H) / (MAX_H - MIN_H)) * 100);
const diffHombre = famoso.estaturaCm - PROMEDIO_H;
const diffMujer  = famoso.estaturaCm - PROMEDIO_M;

// Category name mapping
const NOMBRES_CATEGORIA: Record<string, string> = {
  'futbol': 'Futbolistas', 'musica': 'Músicos', 'cine-tv': 'Cine y TV',
  'influencers': 'Influencers', 'deportes': 'Deportistas', 'streamers': 'Streamers',
  'politica': 'Políticos', 'la-velada': 'La Velada', 'otros': 'Otros',
};

// Similar height: ±3cm, prioritize same category
const similares = famososData
  .filter(f => f.id !== famoso.id && Math.abs(f.estaturaCm - famoso.estaturaCm) <= 3)
  .sort((a, b) => {
    const aCat = a.categoria === famoso.categoria ? 0 : 1;
    const bCat = b.categoria === famoso.categoria ? 0 : 1;
    if (aCat !== bCat) return aCat - bCat;
    return Math.abs(a.estaturaCm - famoso.estaturaCm) - Math.abs(b.estaturaCm - famoso.estaturaCm);
  })
  .slice(0, 5);

// Popular comparisons from keyword research (top-comparaciones.json)
const comparacionesPopulares = comparacionesData
  .filter(c => c.famoso_a === famoso.id || c.famoso_b === famoso.id)
  .slice(0, 5)
  .map(c => {
    const otherId = c.famoso_a === famoso.id ? c.famoso_b : c.famoso_a;
    const other = famososData.find(f => f.id === otherId);
    return { slug: c.slug, other, diff: c.diff_cm, volume: c.search_volume };
  })
  .filter(c => c.other);

// Same category (exclude those already in similares)
const similarIds = new Set(similares.map(s => s.id));
const mismaCategoria = famososData
  .filter(f => f.id !== famoso.id && f.categoria === famoso.categoria && !similarIds.has(f.id))
  .sort((a, b) => Math.abs(a.estaturaCm - famoso.estaturaCm) - Math.abs(b.estaturaCm - famoso.estaturaCm))
  .slice(0, 3);

// Same country
const mismoPais = famososData
  .filter(f => f.id !== famoso.id && f.pais === famoso.pais)
  .slice(0, 3);

// Related rankings
const rankingsRelacionados = rankingsData.filter(r =>
  r.categoria === famoso.categoria || r.slug === 'los-mas-altos' || r.slug === 'los-mas-bajos'
).slice(0, 3);

const defaultB = (famoso.id === 'lionel-messi' ? 'cristiano-ronaldo' : 'lionel-messi');

// Find a valid comparison link: prefer top-comparaciones slug, fallback to homepage
const defaultComp = comparacionesData.find(c =>
  (c.famoso_a === famoso.id && c.famoso_b === defaultB) ||
  (c.famoso_b === famoso.id && c.famoso_a === defaultB)
);
const firstComp = comparacionesPopulares[0];
const compararHref = defaultComp
  ? `/comparar/${defaultComp.slug}`
  : firstComp
    ? `/comparar/${firstComp.slug}`
    : `/?a=${famoso.id}&b=${defaultB}`;
const compararLabel = defaultComp
  ? famososData.find(f => f.id === defaultB)?.nombre?.split(' ')[0] || 'otro famoso'
  : firstComp
    ? firstComp.other?.nombre?.split(' ')[0] || 'otro famoso'
    : famososData.find(f => f.id === defaultB)?.nombre?.split(' ')[0] || 'otro famoso';

// Person schema
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": famoso.fullName || famoso.nombre,
  ...(famoso.apodo ? { "alternateName": famoso.apodo } : {}),
  "height": { "@type": "QuantitativeValue", "value": famoso.estaturaCm, "unitCode": "CMT" },
  ...(famoso.peso ? { "weight": { "@type": "QuantitativeValue", "value": typeof famoso.peso === 'number' ? famoso.peso : parseInt(famoso.peso), "unitCode": "KGM" } } : {}),
  "nationality": { "@type": "Country", "name": famoso.pais },
  "jobTitle": famoso.profesion,
  "description": `${famoso.nombre} mide ${famoso.estaturaCm} cm (${cmToFtIn(famoso.estaturaCm)}). Descubre su estatura y compárala con otros famosos.`,
  ...(famoso.foto ? { "image": famoso.foto } : {}),
  "url": `https://estaturas.com/${famoso.id}`,
};

// BreadcrumbList schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://estaturas.com/" },
    { "@type": "ListItem", "position": 2, "name": NOMBRES_CATEGORIA[famoso.categoria] || famoso.categoria, "item": `https://estaturas.com/categoria/${famoso.categoria}` },
    { "@type": "ListItem", "position": 3, "name": famoso.nombre },
  ],
};

// Combined schemas
const schema = [personSchema, breadcrumbSchema];

// Silhouette proportional height for hero (max display 240px)
const MAX_DISPLAY = 240;
const refH = 210; // reference (tallest likely person)
const heroDisplayH = Math.round((famoso.estaturaCm / refH) * MAX_DISPLAY);
const heroW = Math.round(heroDisplayH * 0.4);
---
<Base
  title={`¿Cuánto mide ${famoso.nombre}? | ${famoso.estaturaCm} cm - Estaturas.com`}
  description={`¿Cuánto mide ${famoso.nombre}? ${famoso.nombre} mide ${famoso.estaturaCm} cm (${cmToFtIn(famoso.estaturaCm)}). Compara su estatura con otros famosos.`}
  schema={schema}
>

  <!-- ── Hero visual ── -->
  <section class="relative overflow-hidden" style={`background: radial-gradient(ellipse 60% 50% at 50% 0%, ${famoso.color}15 0%, transparent 70%)`}>
    <div class="max-w-5xl mx-auto px-4 pt-10 pb-2">
      <nav class="text-sm text-stone-500 mb-8 flex items-center gap-2 flex-wrap">
        <a href="/" class="hover:text-stone-300 transition-colors">Inicio</a>
        <span>›</span>
        <a href={`/categoria/${famoso.categoria}`} class="hover:text-stone-300 transition-colors">{NOMBRES_CATEGORIA[famoso.categoria] || famoso.categoria}</a>
        <span>›</span>
        <span class="text-stone-300">{famoso.nombre}</span>
      </nav>

      <div class="flex flex-col sm:flex-row items-center sm:items-end gap-8">

        <!-- Big silhouette -->
        <div class="relative flex-shrink-0 flex items-end justify-center"
          style={`height: ${MAX_DISPLAY + 20}px; width: ${Math.max(heroW + 40, 100)}px`}>

          <!-- Glow disc at feet -->
          <div class="absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full blur-xl opacity-40"
            style={`width: ${heroDisplayH * 0.6}px; height: 24px; background: ${famoso.color}`} />

          <svg width={heroW} height={heroDisplayH} viewBox="0 0 40 100" overflow="visible">
            <defs>
              <linearGradient id="hero-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color={famoso.color} stop-opacity="1" />
                <stop offset="100%" stop-color={famoso.color} stop-opacity="0.4" />
              </linearGradient>
              <filter id="hero-glow">
                <feGaussianBlur stdDeviation="2" result="blur" />
                <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
              </filter>
            </defs>
            <ellipse cx="20" cy="7.5" rx="7.5" ry="8" fill="url(#hero-grad)" filter="url(#hero-glow)" />
            <rect x="17" y="15.5" width="6" height="3.5" rx="1" fill="url(#hero-grad)" />
            <path d="M17,19 Q4,20 3,26 L37,26 Q36,20 23,19 Z" fill="url(#hero-grad)" />
            <path d="M3,26 L0,54 L7,54 L8,26 Z" fill="url(#hero-grad)" />
            <path d="M37,26 L40,54 L33,54 L32,26 Z" fill="url(#hero-grad)" />
            <path d="M8,26 L32,26 L30,58 L10,58 Z" fill="url(#hero-grad)" />
            <path d="M10,57 L20,57 L19.5,100 L10,100 Z" fill="url(#hero-grad)" />
            <path d="M20,57 L30,57 L30,100 L20.5,100 Z" fill="url(#hero-grad)" />
            <!-- Highlight -->
            <path d="M18,19 Q20,18 22,19 L21.5,55 L18.5,55 Z" fill="white" opacity="0.12" />
          </svg>

          <!-- Height ruler line -->
          <div class="absolute right-0 top-0 bottom-4 flex flex-col items-center justify-between"
            style="width: 2px; background: linear-gradient(to bottom, transparent, rgba(148,163,184,0.3));">
            <span class="text-xs font-bold whitespace-nowrap ml-3 mt-1" style={`color: ${famoso.color}`}>
              {famoso.estaturaCm}cm
            </span>
          </div>
        </div>

        <!-- Name & stats -->
        <div class="flex-1 text-center sm:text-left pb-4">
          <div class="flex items-center gap-2 justify-center sm:justify-start mb-3">
            <span class="text-2xl">{famoso.bandera}</span>
            <span class="text-sm px-3 py-1 rounded-full font-medium"
              style={`background: ${famoso.color}18; color: ${famoso.color}; border: 1px solid ${famoso.color}30`}>
              {famoso.profesion}
            </span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-black text-white leading-tight mb-1">
            {famoso.nombre}
          </h1>
          {(famoso as any).fullName && (famoso as any).fullName !== famoso.nombre && (
            <p class="text-stone-500 text-base mb-1">{(famoso as any).fullName}</p>
          )}
          {famoso.apodo && (
            <p class="text-stone-400 text-lg mb-4">"{famoso.apodo}"</p>
          )}
          <div class="flex items-baseline gap-4 justify-center sm:justify-start mt-4">
            <span class="text-6xl font-black" style={`color: ${famoso.color}`}>
              {famoso.estaturaCm}
            </span>
            <div>
              <p class="text-stone-300 font-semibold text-xl">cm</p>
              <p class="text-stone-500 text-sm">{cmToFtIn(famoso.estaturaCm)}</p>
            </div>
          </div>

          <a href={compararHref}
            class="btn-glow inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-xl font-bold text-white text-sm"
            style="background: linear-gradient(135deg, #d97706, #f59e0b);">
            🔄 Compara con {compararLabel}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Content ── -->
  <div class="max-w-5xl mx-auto px-4 py-12 space-y-12">

    <!-- Stats grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 reveal">
      {[
        { label: 'Estatura', value: `${famoso.estaturaCm}cm` },
        { label: 'En pies', value: cmToFtIn(famoso.estaturaCm) },
        { label: 'Peso', value: famoso.peso ? `${famoso.peso}kg` : 'N/D' },
        { label: 'Edad', value: famoso.edad ? `${famoso.edad} años` : 'N/D' },
        { label: 'vs. ♂ español', value: `${diffHombre > 0 ? '+' : ''}${diffHombre}cm`, color: diffHombre >= 0 ? '#34d399' : '#f87171' },
        { label: 'vs. ♀ española', value: `${diffMujer > 0 ? '+' : ''}${diffMujer}cm`, color: diffMujer >= 0 ? '#34d399' : '#f87171' },
        { label: 'País', value: `${famoso.bandera} ${famoso.pais}` },
        { label: 'Profesión', value: famoso.profesion?.split('/')[0].trim() ?? 'N/D' },
      ].map(s => (
        <div class="glass rounded-xl px-4 py-3.5">
          <p class="text-stone-500 text-xs uppercase tracking-wider mb-1.5">{s.label}</p>
          <p class="font-bold text-sm" style={s.color ? `color: ${s.color}` : 'color: white'}>{s.value}</p>
        </div>
      ))}
    </div>

    <!-- Progress bar — human height range -->
    <div class="glass rounded-2xl p-6 reveal">
      <div class="flex items-center justify-between mb-3">
        <p class="text-stone-400 text-sm">Posición en el rango humano</p>
        <p class="text-stone-500 text-xs">55cm — 272cm</p>
      </div>
      <div class="relative h-3 rounded-full overflow-hidden" style="background: rgba(148,163,184,0.1)">
        <!-- Average markers -->
        <div class="absolute top-0 bottom-0 w-px opacity-50"
          style={`left: ${((PROMEDIO_H - MIN_H)/(MAX_H - MIN_H)*100).toFixed(1)}%; background: #94a3b8`} />
        <!-- Fill -->
        <div class="h-full rounded-full transition-all duration-1000 ease-out"
          style={`width: ${barPct}%; background: linear-gradient(to right, ${famoso.color}88, ${famoso.color})`} />
        <!-- Person marker -->
        <div class="absolute top-1/2 -translate-y-1/2 w-4 h-4 rounded-full border-2 -ml-2"
          style={`left: ${barPct}%; background: ${famoso.color}; border-color: white`} />
      </div>
      <div class="flex justify-between text-xs text-stone-600 mt-2">
        <span>Más bajo</span>
        <span class="font-semibold" style={`color: ${famoso.color}`}>{famoso.nombre.split(' ')[0]}: {famoso.estaturaCm}cm</span>
        <span>Más alto</span>
      </div>
    </div>

    <!-- Fun fact -->
    {(famoso as any).funFact && (
      <div class="glass rounded-2xl p-6 reveal" style={`border-left: 3px solid ${famoso.color}`}>
        <div class="flex items-start gap-3">
          <span class="text-2xl flex-shrink-0">💡</span>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider mb-1.5" style={`color: ${famoso.color}`}>¿Sabías que…?</p>
            <p class="text-stone-300 leading-relaxed">{(famoso as any).funFact}</p>
          </div>
        </div>
      </div>
    )}

    <!-- Context paragraph -->
    <div class="glass rounded-2xl p-6 reveal">
      <h2 class="text-lg font-bold text-white mb-3">¿Qué tan alto/a es {famoso.nombre.split(' ')[0]}?</h2>
      <p class="text-stone-400 leading-relaxed">
        <strong class="text-white">{famoso.nombre}</strong> mide <strong class="text-white">{famoso.estaturaCm}cm</strong> ({cmToFtIn(famoso.estaturaCm)}){famoso.apodo ? `, conocido/a como "${famoso.apodo}",` : ''} y es {famoso.profesion?.toLowerCase()} de {famoso.pais}.
        {diffHombre > 0
          ? ` Esto le sitúa ${diffHombre}cm por encima del promedio del hombre español (176cm).`
          : diffHombre < 0
          ? ` Esto le sitúa ${Math.abs(diffHombre)}cm por debajo del promedio del hombre español (176cm).`
          : ` Coincide exactamente con el promedio del hombre español (176cm).`}
        {diffMujer > 0
          ? ` Respecto a la mujer española (163cm de media), {famoso.nombre.split(' ')[0]} es ${diffMujer}cm más alto/a.`
          : ''}
      </p>
    </div>

    <!-- Comparador inline -->
    <div class="reveal">
      <h2 class="text-xl font-black text-white mb-4">Comparador interactivo</h2>
      <Comparador client:idle famosos={famososData} inicial={{ a: famoso.id, b: defaultB }} />
    </div>

    <!-- Comparaciones populares -->
    {comparacionesPopulares.length > 0 && (
      <div class="reveal">
        <h2 class="text-xl font-black text-white mb-4">Comparaciones populares</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {comparacionesPopulares.map(({ slug, other, diff }) => (
            <a href={`/comparar/${slug}`}
              class="glass rounded-xl px-4 py-3 flex items-center justify-between group transition-all hover:-translate-y-0.5">
              <span class="text-slate-300 group-hover:text-white text-sm transition-colors">
                {famoso.nombre.split(' ')[0]} vs {other.nombre}
              </span>
              <span class="text-sm font-semibold" style={`color: ${other.color}`}>
                {diff > 0 ? `${diff}cm de diferencia` : 'Misma estatura'}
              </span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Famosos de estatura similar -->
    {similares.length > 0 && (
      <div class="reveal">
        <h2 class="text-xl font-black text-white mb-4">
          Famosos con estatura similar <span class="text-stone-500 font-normal text-base">(±3cm)</span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
          {similares.map(s => (
            <a href={`/${s.id}`}
              class="famoso-card glass rounded-2xl p-4 text-center"
              onmouseover={`this.style.borderColor='${s.color}44'`}
              onmouseout={`this.style.borderColor=''`}>
              <span class="text-2xl block mb-2">{s.bandera}</span>
              <p class="text-white text-sm font-bold">{s.nombre.split(' ')[0]}</p>
              <p class="text-xs mt-1 font-semibold" style={`color: ${s.color}`}>{s.estaturaCm}cm</p>
              <p class="text-stone-600 text-xs">{s.profesion?.split('/')[0].trim()}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Misma categoría -->
    {mismaCategoria.length > 0 && (
      <div class="reveal">
        <h2 class="text-xl font-black text-white mb-4">
          Más {NOMBRES_CATEGORIA[famoso.categoria]?.toLowerCase() || famoso.categoria}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
          {mismaCategoria.map(f => (
            <a href={`/${f.id}`}
              class="glass rounded-xl px-4 py-3 flex items-center justify-between group transition-all hover:-translate-y-0.5">
              <span class="text-stone-300 group-hover:text-white text-sm transition-colors">
                {f.bandera} {f.nombre}
              </span>
              <span class="text-sm font-semibold" style={`color: ${f.color}`}>{f.estaturaCm}cm</span>
            </a>
          ))}
        </div>
        <a href={`/categoria/${famoso.categoria}`}
          class="inline-block mt-3 text-sm text-stone-500 hover:text-stone-300 transition-colors">
          Ver todos los {NOMBRES_CATEGORIA[famoso.categoria]?.toLowerCase()} →
        </a>
      </div>
    )}

    <!-- Mismo país -->
    {mismoPais.length > 0 && (
      <div class="reveal">
        <h2 class="text-xl font-black text-white mb-4">
          Famosos de {famoso.pais} {famoso.bandera}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
          {mismoPais.map(f => (
            <a href={`/${f.id}`}
              class="glass rounded-xl px-4 py-3 flex items-center justify-between group transition-all hover:-translate-y-0.5">
              <span class="text-slate-300 group-hover:text-white text-sm transition-colors">
                {f.nombre}
              </span>
              <span class="text-sm font-semibold" style={`color: ${f.color}`}>{f.estaturaCm}cm</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Rankings relacionados -->
    {rankingsRelacionados.length > 0 && (
      <div class="reveal">
        <h2 class="text-xl font-black text-white mb-4">Rankings relacionados</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
          {rankingsRelacionados.map(r => (
            <a href={`/ranking/${r.slug}`}
              class="glass rounded-xl px-4 py-3 group transition-all hover:-translate-y-0.5">
              <span class="text-slate-300 group-hover:text-white text-sm transition-colors">
                {r.titulo}
              </span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</Base>
