---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const title = 'Blog - Noticias y curiosidades sobre estaturas | estaturas.com';
const description = 'Artículos sobre las estaturas de famosos, eventos como La Velada, comparaciones curiosas y datos que no sabías.';
---
<Base title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <nav class="text-sm text-slate-500 mb-6 flex items-center gap-2">
      <a href="/" class="hover:text-slate-300 transition-colors">Inicio</a>
      <span>›</span>
      <span class="text-slate-300">Blog</span>
    </nav>

    <h1 class="text-4xl font-black text-white mb-3">Blog</h1>
    <p class="text-slate-400 mb-10">Artículos, curiosidades y análisis sobre las estaturas del mundo del streaming, la música y el deporte.</p>

    <div class="space-y-4">
      {posts.map(post => (
        <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="block glass rounded-2xl p-6 transition-all hover:-translate-y-0.5 group">
          <div class="flex items-center gap-3 mb-2">
            <time class="text-xs text-slate-500">{new Date(post.data.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
            {post.data.tags.slice(0, 3).map(tag => (
              <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background: #ec489922; color: #ec4899;">{tag}</span>
            ))}
          </div>
          <h2 class="text-xl font-bold text-white group-hover:text-pink-400 transition-colors mb-2">{post.data.title}</h2>
          <p class="text-slate-400 text-sm line-clamp-2">{post.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
