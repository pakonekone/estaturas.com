---
import Base from '../layouts/Base.astro';
import Comparador from '../components/Comparador';
import famosos from '../data/famosos.json';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Comparador de Estaturas de Famosos",
  "url": "https://estaturas.com",
  "description": "Compara visualmente la estatura de famosos. Gratis e interactivo.",
  "applicationCategory": "LifestyleApplication",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
};

const pairs = [
  { a: 'lionel-messi', b: 'cristiano-ronaldo', label: 'Messi vs CR7' },
  { a: 'lebron-james', b: 'lionel-messi', label: 'LeBron vs Messi' },
  { a: 'shaquille-oneal', b: 'simone-biles', label: 'Shaq vs Simone Biles' },
  { a: 'taylor-swift', b: 'shakira', label: 'Taylor vs Shakira' },
  { a: 'erling-haaland', b: 'luka-modric', label: 'Haaland vs Modrić' },
  { a: 'elrubius', b: 'ibai', label: 'ElRubius vs Ibai' },
];

const totalComparaciones = famosos.length * (famosos.length - 1) / 2;
const stats = [
  { n: String(famosos.length), label: 'famosos' },
  { n: String(totalComparaciones), label: 'comparaciones' },
  { n: '5', label: 'personas máx.' },
];
---
<Base
  title="Comparador de Estaturas de Famosos — estaturas.com"
  description="¿Cuánto mide Messi? ¿LeBron es más alto que Cristiano? Compara visualmente la estatura de tus famosos favoritos. Gratis, rápido, shareable."
  schema={schema}
>
  <!-- ── Hero ── -->
  <section class="max-w-6xl mx-auto px-4 pt-16 pb-6 text-center">
    <div class="hero-1 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest mb-8 px-4 py-2 rounded-full"
      style="background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.25); color: #f59e0b;">
      📏 Comparador de estaturas en español
    </div>

    <h1 class="hero-2 text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.08] tracking-tight mb-6">
      ¿Cuánto miden<br />
      <span class="text-gradient">tus famosos favoritos?</span>
    </h1>

    <p class="hero-3 text-stone-400 text-lg sm:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
      Messi, Bad Bunny, Zendaya... ¿quién es más alto? Compáralos visualmente y métete tú en la foto.
    </p>

    <!-- Stats row -->
    <div class="hero-4 flex items-center justify-center gap-8 mb-12">
      {stats.map(s => (
        <div class="text-center">
          <p class="text-2xl font-black text-white">{s.n}</p>
          <p class="text-stone-500 text-xs uppercase tracking-wide">{s.label}</p>
        </div>
      ))}
    </div>

    <!-- Quick pair links -->
    <div class="hero-4 flex flex-wrap justify-center gap-2 mb-14">
      {pairs.map(p => (
        <a href={`/comparar/${p.a}-vs-${p.b}`}
          class="glass text-stone-400 hover:text-white text-sm px-3.5 py-1.5 rounded-full transition-all hover:-translate-y-0.5">
          {p.label}
        </a>
      ))}
    </div>
  </section>

  <!-- ── Comparador ── -->
  <section class="max-w-3xl mx-auto px-4 pb-20">
    <Comparador client:load famosos={famosos} />
  </section>

  <!-- ── Features ── -->
  <section class="border-t py-16 reveal" style="border-color: rgba(255,245,235,0.06);">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { icon: '👥', title: 'Hasta 5 personas', desc: 'Mete a Shaq, a Messi y a ti mismo. Verás la diferencia.' },
          { icon: '📸', title: 'Imagen descargable', desc: 'Descarga la comparación como imagen y que tus amigos alucinen.' },
          { icon: '🔗', title: 'Enlace único', desc: 'Copia el enlace y envíaselo a quien quieras. Cada comparación tiene su URL.' },
        ].map(f => (
          <div class="glass rounded-2xl p-6 transition-all hover:-translate-y-1">
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="font-bold text-white mb-2">{f.title}</h3>
            <p class="text-stone-400 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Famosos grid with photos ── -->
  <section class="max-w-6xl mx-auto px-4 py-12 reveal">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-black text-white">Famosos más buscados</h2>
      <a href="/famosos" class="text-sm font-semibold transition-colors hover:opacity-80"
        style="color: #f59e0b">Ver todos →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      {famosos.slice(0, 10).map(f => (
        <a href={`/${f.id}`}
          class="famoso-card glass rounded-2xl p-4 text-center"
          style={`--glow: ${f.color}`}
          onmouseover={`this.style.boxShadow='0 0 20px ${f.color}33'; this.style.borderColor='${f.color}44'`}
          onmouseout={`this.style.boxShadow=''; this.style.borderColor=''`}>
          <!-- Photo/Avatar -->
          <div class="w-14 h-14 mx-auto mb-3 rounded-full overflow-hidden"
            style={f.foto ? '' : `background: linear-gradient(135deg, ${f.color}40, ${f.color}20)`}>
            {f.foto ? (
              <img src={f.foto} alt={f.nombre} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <svg viewBox="0 0 100 100" class="w-full h-full" aria-hidden="true">
                <circle cx="50" cy="35" r="18" fill={`${f.color}80`} />
                <ellipse cx="50" cy="85" rx="30" ry="22" fill={`${f.color}60`} />
              </svg>
            )}
          </div>
          <p class="text-white text-sm font-bold leading-tight mb-1">
            {f.nombre.split(' ')[0]}
          </p>
          <p class="text-xs font-semibold" style={`color: ${f.color}`}>{f.estaturaCm}cm</p>
          <p class="text-stone-600 text-xs mt-0.5">{f.profesion?.split('/')[0].trim()}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Trending comparisons ── -->
  <section class="max-w-6xl mx-auto px-4 py-12 reveal">
    <h2 class="text-2xl font-black text-white mb-2">🔥 Los más buscados</h2>
    <p class="text-stone-400 text-sm mb-6">Las comparaciones más populares</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {[
        { a: 'lionel-messi', b: 'cristiano-ronaldo', emoji: '⚽' },
        { a: 'taylor-swift', b: 'bad-bunny', emoji: '🎵' },
        { a: 'tom-holland', b: 'zendaya', emoji: '🎬' },
        { a: 'shaquille-oneal', b: 'simone-biles', emoji: '😱' },
        { a: 'ibai', b: 'elrubius', emoji: '🎮' },
        { a: 'erling-haaland', b: 'lionel-messi', emoji: '⚽' },
      ].map(pair => {
        const fa = famosos.find(f => f.id === pair.a);
        const fb = famosos.find(f => f.id === pair.b);
        if (!fa || !fb) return null;
        const diff = Math.abs(fa.estaturaCm - fb.estaturaCm);
        return (
          <a href={`/comparar/${pair.a}-vs-${pair.b}`}
            class="glass rounded-xl p-4 flex items-center gap-3 group transition-all hover:-translate-y-1">
            <span class="text-2xl">{pair.emoji}</span>
            <div class="flex-1 min-w-0">
              <p class="text-white text-sm font-bold group-hover:text-brand-400 transition-colors truncate">
                {fa.nombre} vs {fb.nombre}
              </p>
              <p class="text-stone-500 text-xs">{diff}cm de diferencia</p>
            </div>
            <span class="text-stone-600 text-xs">→</span>
          </a>
        );
      })}
    </div>
  </section>

  <!-- ── Category quick links ── -->
  <section class="max-w-6xl mx-auto px-4 py-8 reveal">
    <h2 class="text-2xl font-black text-white mb-6">Explora por categoría</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { href: '/famosos', emoji: '⚽', label: 'Futbolistas', count: famosos.filter(f => f.categoria === 'futbol').length },
        { href: '/famosos', emoji: '🎵', label: 'Cantantes', count: famosos.filter(f => f.categoria === 'musica').length },
        { href: '/famosos', emoji: '🎬', label: 'Actores', count: famosos.filter(f => f.categoria === 'cine-tv').length },
        { href: '/famosos', emoji: '📱', label: 'Streamers', count: famosos.filter(f => f.categoria === 'influencers').length },
      ].map(cat => (
        <a href={cat.href}
          class="glass rounded-2xl p-5 text-center group transition-all hover:-translate-y-1">
          <span class="text-4xl block mb-2">{cat.emoji}</span>
          <p class="font-bold text-white group-hover:text-brand-400">{cat.label}</p>
          <p class="text-stone-500 text-xs mt-1">{cat.count} famosos</p>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Rankings teaser ── -->
  <section class="max-w-6xl mx-auto px-4 pb-20 reveal">
    <h2 class="text-2xl font-black text-white mb-6">Rankings y quizzes</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {[
        { href: '/ranking/futbolistas-mas-altos', emoji: '⚽', title: 'Futbolistas más altos', desc: 'Los gigantes del fútbol mundial' },
        { href: '/ranking/famosos-espanoles', emoji: '🇪🇸', title: 'Famosos españoles', desc: 'Cuánto miden Rosalía, Pedri y más' },
        { href: '/quiz', emoji: '🎯', title: 'Adivina la estatura', desc: 'Quiz con racha y récord personal' },
      ].map(r => (
        <a href={r.href}
          class="glass rounded-2xl p-5 flex gap-4 items-start transition-all hover:-translate-y-1 group">
          <span class="text-3xl mt-0.5">{r.emoji}</span>
          <div>
            <p class="font-bold text-white group-hover:text-brand-400 transition-colors">{r.title}</p>
            <p class="text-stone-400 text-sm mt-0.5">{r.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
