---
import Base from '../../layouts/Base.astro';
import Comparador from '../../components/Comparador';
import famososData from '../../data/famosos.json';
import { cmToFtIn } from '../../utils/height';

export function getStaticPaths() {
  const paths = [];
  for (let i = 0; i < famososData.length; i++) {
    for (let j = i + 1; j < famososData.length; j++) {
      paths.push({
        params: { slug: `${famososData[i].id}-vs-${famososData[j].id}` },
        props: { aId: famososData[i].id, bId: famososData[j].id },
      });
    }
  }
  return paths;
}

const { aId, bId } = Astro.props;
const personaA = famososData.find(f => f.id === aId)!;
const personaB = famososData.find(f => f.id === bId)!;

const diff = Math.abs(personaA.estaturaCm - personaB.estaturaCm);
const masAlto = personaA.estaturaCm >= personaB.estaturaCm ? personaA : personaB;
const masCorto = personaA.estaturaCm < personaB.estaturaCm ? personaA : personaB;

const title = `${personaA.nombre} vs ${personaB.nombre} — Comparativa de Estaturas`;
const description = `${personaA.nombre} mide ${personaA.estaturaCm}cm y ${personaB.nombre} mide ${personaB.estaturaCm}cm. ${masAlto.nombre} es ${diff}cm más alto/a. Comparativa visual interactiva.`;
---
<Base title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-stone-500 mb-6 flex items-center gap-2">
      <a href="/" class="hover:text-stone-300 transition-colors">Inicio</a>
      <span>›</span>
      <span class="text-stone-300">Comparar</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-2 text-center">
      {personaA.nombre} <span class="text-stone-500">vs</span> {personaB.nombre}
    </h1>
    <p class="text-center text-stone-400 mb-8">{description}</p>

    <!-- Quick stats -->
    <div class="grid grid-cols-2 gap-4 mb-8">
      {[personaA, personaB].map(p => (
        <a href={`/${p.id}`}
          class="bg-stone-900 border border-stone-800 hover:border-slate-600 rounded-2xl p-5 text-center transition-all group"
          style={`border-color: ${p.color}44`}>
          <div class="text-3xl mb-2">{p.bandera}</div>
          <h2 class="font-bold text-white group-hover:text-brand-400 transition-colors mb-1">{p.nombre}</h2>
          <p class="text-3xl font-black" style={`color: ${p.color}`}>{p.estaturaCm}cm</p>
          <p class="text-stone-400 text-sm">{cmToFtIn(p.estaturaCm)}</p>
          <p class="text-stone-500 text-xs mt-1">{p.profesion}</p>
        </a>
      ))}
    </div>

    <!-- Result verdict -->
    <div class="bg-stone-900 border border-brand-700/40 rounded-2xl p-5 text-center mb-8">
      <p class="text-stone-400 text-sm mb-1">Diferencia de estatura</p>
      <p class="text-4xl font-black text-white">{diff}cm</p>
      <p class="text-stone-400 mt-2">
        <strong class="text-white">{masAlto.nombre}</strong> es {diff}cm más alto/a que <strong class="text-white">{masCorto.nombre}</strong>
      </p>
    </div>

    <!-- Interactive comparator -->
    <Comparador client:load famosos={famososData} inicial={{ a: aId, b: bId }} />

    <!-- Related comparisons -->
    <section class="mt-12">
      <h2 class="text-xl font-bold text-white mb-4">Otras comparaciones</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {famososData
          .filter(f => f.id !== aId && f.id !== bId)
          .slice(0, 4)
          .map(other => (
            <a href={`/comparar/${aId}-vs-${other.id}`}
              class="bg-stone-900 hover:bg-stone-800 border border-stone-800 hover:border-slate-700 rounded-xl p-4 flex items-center justify-between transition-all group">
              <span class="text-stone-300 group-hover:text-white transition-colors text-sm">
                {personaA.nombre} vs {other.nombre}
              </span>
              <span class="text-stone-500 text-sm">{other.estaturaCm}cm</span>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Base>
