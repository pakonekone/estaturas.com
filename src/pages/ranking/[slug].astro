---
import Base from '../../layouts/Base.astro';
import famososData from '../../data/famosos.json';
import rankingsData from '../../data/rankings.json';
import { cmToFtIn } from '../../utils/height';

export function getStaticPaths() {
  return rankingsData.map(r => ({
    params: { slug: r.slug },
    props: { ranking: r },
  }));
}

const { ranking } = Astro.props;

// Filter logic
let filtered = [...famososData];

if (ranking.categoria) {
  filtered = filtered.filter(f => f.categoria === ranking.categoria);
}
if (ranking.filtroPais === 'espana') {
  filtered = filtered.filter(f => f.pais.toLowerCase().includes('españa'));
}
if (ranking.filtrosPais) {
  filtered = filtered.filter(f => (ranking as any).filtrosPais.includes(f.pais));
}

const sorted = filtered.sort((a, b) =>
  ranking.orden === 'asc' ? a.estaturaCm - b.estaturaCm : b.estaturaCm - a.estaturaCm
);

const top = sorted.slice(0, 15);
const maxCm = ranking.orden === 'desc' ? (top[0]?.estaturaCm ?? 1) : (top[top.length-1]?.estaturaCm ?? 1);
const refCm = Math.max(...top.map(f => f.estaturaCm));
---
<Base
  title={`${ranking.titulo} | estaturas.com`}
  description={ranking.descripcion}
>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <nav class="text-sm text-slate-500 mb-6 flex items-center gap-2">
      <a href="/" class="hover:text-slate-300 transition-colors">Inicio</a>
      <span>›</span>
      <span class="text-slate-300">Rankings</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-black text-white mb-2">{ranking.titulo}</h1>
    <p class="text-slate-400 mb-10 text-lg">{ranking.descripcion}</p>

    <div class="space-y-2.5">
      {top.map((f, i) => {
        const barPct = (f.estaturaCm / refCm) * 100;
        const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : null;
        return (
          <a href={`/${f.id}`}
            class="group block glass rounded-2xl p-4 transition-all hover:-translate-y-0.5"
            onmouseover={`this.style.borderColor='${f.color}44'`}
            onmouseout={`this.style.borderColor=''`}>
            <div class="flex items-center gap-3 sm:gap-4">
              <div class="w-8 flex-shrink-0 text-center">
                {medal
                  ? <span class="text-xl">{medal}</span>
                  : <span class="text-slate-500 font-mono text-sm font-bold">{i + 1}</span>
                }
              </div>
              <div class="text-xl flex-shrink-0">{f.bandera}</div>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline justify-between mb-1.5">
                  <div class="min-w-0">
                    <p class="font-bold text-white group-hover:text-sky-400 transition-colors truncate">
                      {f.nombre}
                    </p>
                    <p class="text-slate-500 text-xs truncate">{f.profesion?.split('/')[0].trim()}</p>
                  </div>
                  <div class="text-right flex-shrink-0 ml-3">
                    <span class="font-black text-xl" style={`color: ${f.color}`}>{f.estaturaCm}cm</span>
                    <span class="text-slate-500 text-xs ml-1.5 hidden sm:inline">{cmToFtIn(f.estaturaCm)}</span>
                  </div>
                </div>
                <div class="w-full rounded-full h-1.5" style="background: rgba(148,163,184,0.1)">
                  <div class="h-1.5 rounded-full transition-all duration-700"
                    style={`width: ${barPct}%; background: linear-gradient(to right, ${f.color}88, ${f.color})`} />
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <!-- CTA -->
    <div class="mt-10 text-center">
      <a href="/"
        class="btn-glow inline-flex items-center gap-2 text-white font-bold px-6 py-3 rounded-xl"
        style="background: linear-gradient(135deg, #0284c7, #0ea5e9)">
        🔄 Comparar estas estaturas
      </a>
    </div>

    <!-- Navigation to other rankings -->
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-3">
      {rankingsData.filter(r => r.slug !== ranking.slug).slice(0, 4).map(r => (
        <a href={`/ranking/${r.slug}`}
          class="glass rounded-xl p-4 text-sm text-slate-400 hover:text-white transition-colors group">
          <p class="font-semibold group-hover:text-sky-400 transition-colors">{r.titulo}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
