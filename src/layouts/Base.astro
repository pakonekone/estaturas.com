---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  schema?: object | object[];
}
const {
  title,
  description = 'Compara la estatura de famosos y celebridades. Comparador visual interactivo. ¿Cuánto mide Messi? ¿Y LeBron James?',
  ogImage = '/og-default.png',
  canonical,
  schema,
} = Astro.props;

const siteUrl = 'https://estaturas.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="estaturas.com" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {schema && (Array.isArray(schema)
    ? schema.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)} />)
    : <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-LY7L2J94Q7"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LY7L2J94Q7');
  </script>
</head>
<body>
  <!-- Header -->
  <header class="sticky top-0 z-50 border-b" style="background: rgba(15,13,19,0.85); backdrop-filter: blur(16px); border-color: rgba(255,245,235,0.06);">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-black text-lg tracking-tight hover:opacity-80 transition-opacity">
        <span class="text-xl">📏</span>
        <span class="text-white">estaturas<span style="color: #f59e0b">.com</span></span>
      </a>
      <nav class="flex items-center gap-1">
        {[
          { href: '/famosos', label: 'Famosos' },
          { href: '/blog', label: 'Blog' },
          { href: '/quiz', label: 'Quiz' },
          { href: '/ranking/futbolistas-mas-altos', label: 'Rankings' },
        ].map(n => (
          <a href={n.href}
            class="hidden sm:block text-stone-400 hover:text-white px-3 py-1.5 rounded-lg text-sm font-medium transition-colors hover:bg-white/5">
            {n.label}
          </a>
        ))}
        <a href="/" class="ml-2 btn-glow text-sm font-bold text-white px-4 py-1.5 rounded-lg"
          style="background: linear-gradient(135deg, #d97706 0%, #f59e0b 100%);">
          Comparar
        </a>
      </nav>
    </div>
  </header>

  <!-- Main -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t mt-20 py-10" style="border-color: rgba(255,245,235,0.06);">
    <div class="max-w-6xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2 text-stone-500 text-sm">
        <span>📏</span>
        <span class="font-semibold text-stone-400">estaturas.com</span>
        <span>·</span>
        <span>Datos informativos, pueden variar.</span>
      </div>
      <div class="flex items-center gap-4 text-sm text-stone-600">
        <a href="/famosos" class="hover:text-stone-400 transition-colors">Famosos</a>
        <a href="/quiz" class="hover:text-stone-400 transition-colors">Quiz</a>
        <a href="/ranking/futbolistas-mas-altos" class="hover:text-stone-400 transition-colors">Rankings</a>
      </div>
    </div>
  </footer>

  <!-- Scroll reveal observer -->
  <script>
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>
</body>
</html>
