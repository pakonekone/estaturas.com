---
interface Props {
  id: string;
  nombre: string;
  foto: string | null;
  color: string;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { id, nombre, foto, color, size = 'md', class: className = '' } = Astro.props;

const sizes = {
  sm: 'w-10 h-10',
  md: 'w-16 h-16',
  lg: 'w-24 h-24',
};
---
<div class={`rounded-full overflow-hidden flex-shrink-0 ${sizes[size]} ${className}`}
  style={foto ? '' : `background: linear-gradient(135deg, ${color}40, ${color}20)`}>
  {foto ? (
    <img src={foto} alt={`Foto de ${nombre}`}
      class="w-full h-full object-cover"
      loading="lazy" decoding="async" />
  ) : (
    <svg viewBox="0 0 100 100" class="w-full h-full" aria-hidden="true">
      <circle cx="50" cy="35" r="18" fill={`${color}80`} />
      <ellipse cx="50" cy="85" rx="30" ry="22" fill={`${color}60`} />
    </svg>
  )}
</div>
