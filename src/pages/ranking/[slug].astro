---
import Base from '../../layouts/Base.astro';
import famososData from '../../data/famosos.json';
import rankingsData from '../../data/rankings.json';
import rankingsAutoData from '../../data/rankings-auto.json';
import { cmToFtIn } from '../../utils/height';

export function getStaticPaths() {
  const manualSlugs = new Set(rankingsData.map(r => r.slug));

  const manual = rankingsData.map(r => ({
    params: { slug: r.slug },
    props: {
      titulo: r.titulo,
      descripcion: r.descripcion,
      intro: undefined as string | undefined,
      conclusion: undefined as string | undefined,
      categoria: r.categoria ?? null,
      filtroPais: (r as any).filtroPais as string | undefined,
      filtrosPais: (r as any).filtrosPais as string[] | undefined,
      filtroGenero: undefined as string | undefined,
      orden: r.orden as 'asc' | 'desc',
    },
  }));

  const auto = rankingsAutoData
    .filter(r => !manualSlugs.has(r.slug))
    .map(r => ({
      params: { slug: r.slug },
      props: {
        titulo: r.seo.title.replace(' | estaturas.com', ''),
        descripcion: r.seo.description,
        intro: r.content.intro,
        conclusion: r.content.conclusion,
        categoria: r.filtro.categoria ?? null,
        filtroPais: (r.filtro as any).pais as string | undefined,
        filtrosPais: undefined as string[] | undefined,
        filtroGenero: r.filtro.genero as string | undefined,
        orden: (r.tipo === 'mas-bajos' ? 'asc' : 'desc') as 'asc' | 'desc',
      },
    }));

  return [...manual, ...auto];
}

const { titulo, descripcion, intro, conclusion, categoria, filtroPais, filtrosPais, filtroGenero, orden } = Astro.props;

// Filter logic
let filtered = [...famososData];

if (categoria) {
  filtered = filtered.filter(f => f.categoria === categoria);
}
if (filtroPais === 'espana') {
  filtered = filtered.filter(f => f.pais.toLowerCase().includes('españa'));
} else if (filtroPais) {
  filtered = filtered.filter(f => f.pais === filtroPais);
}
if (filtrosPais) {
  filtered = filtered.filter(f => filtrosPais.includes(f.pais));
}
if (filtroGenero) {
  filtered = filtered.filter(f => f.genero === filtroGenero);
}

const sorted = filtered.sort((a, b) =>
  orden === 'asc' ? a.estaturaCm - b.estaturaCm : b.estaturaCm - a.estaturaCm
);

const top = sorted.slice(0, 15);
const refCm = top.length > 0 ? Math.max(...top.map(f => f.estaturaCm)) : 1;

// Combine all ranking slugs for navigation
const allSlugs = [
  ...rankingsData.map(r => ({ slug: r.slug, titulo: r.titulo })),
  ...rankingsAutoData
    .filter(r => !new Set(rankingsData.map(m => m.slug)).has(r.slug))
    .map(r => ({ slug: r.slug, titulo: r.seo.title.replace(' | estaturas.com', '') })),
];
const currentSlug = Astro.params.slug;
const otherRankings = allSlugs.filter(r => r.slug !== currentSlug);

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": titulo,
  "description": descripcion,
  "numberOfItems": top.length,
  "itemListElement": top.map((f, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Person",
      "name": f.fullName || f.nombre,
      "height": { "@type": "QuantitativeValue", "value": f.estaturaCm, "unitCode": "CMT" },
    }
  })),
};
---
<Base
  title={`${titulo} | Estaturas.com`}
  description={descripcion}
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <nav class="text-sm text-stone-500 mb-6 flex items-center gap-2">
      <a href="/" class="hover:text-stone-300 transition-colors">Inicio</a>
      <span>›</span>
      <span class="text-stone-300">Rankings</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-black text-white mb-2">{titulo}</h1>
    <p class="text-stone-400 mb-4 text-lg">{descripcion}</p>
    {intro && <p class="text-stone-500 mb-8">{intro}</p>}
    {!intro && <div class="mb-6" />}

    <div class="space-y-2.5">
      {top.map((f, i) => {
        const barPct = (f.estaturaCm / refCm) * 100;
        const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : null;
        return (
          <a href={`/${f.id}`}
            class="group block glass rounded-2xl p-4 transition-all hover:-translate-y-0.5"
            onmouseover={`this.style.borderColor='${f.color}44'`}
            onmouseout={`this.style.borderColor=''`}>
            <div class="flex items-center gap-3 sm:gap-4">
              <div class="w-8 flex-shrink-0 text-center">
                {medal
                  ? <span class="text-xl">{medal}</span>
                  : <span class="text-stone-500 font-mono text-sm font-bold">{i + 1}</span>
                }
              </div>
              <div class="text-xl flex-shrink-0">{f.bandera}</div>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline justify-between mb-1.5">
                  <div class="min-w-0">
                    <p class="font-bold text-white group-hover:text-brand-400 transition-colors truncate">
                      {f.nombre}
                    </p>
                    <p class="text-stone-500 text-xs truncate">{f.profesion?.split('/')[0].trim()}</p>
                  </div>
                  <div class="text-right flex-shrink-0 ml-3">
                    <span class="font-black text-xl" style={`color: ${f.color}`}>{f.estaturaCm}cm</span>
                    <span class="text-stone-500 text-xs ml-1.5 hidden sm:inline">{cmToFtIn(f.estaturaCm)}</span>
                  </div>
                </div>
                <div class="w-full rounded-full h-1.5" style="background: rgba(148,163,184,0.1)">
                  <div class="h-1.5 rounded-full transition-all duration-700"
                    style={`width: ${barPct}%; background: linear-gradient(to right, ${f.color}88, ${f.color})`} />
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    {conclusion && (
      <p class="mt-8 text-stone-400 text-sm glass rounded-2xl p-4">{conclusion}</p>
    )}

    <!-- CTA -->
    <div class="mt-10 text-center">
      <a href="/"
        class="btn-glow inline-flex items-center gap-2 text-white font-bold px-6 py-3 rounded-xl"
        style="background: linear-gradient(135deg, #d97706, #f59e0b)">
        🔄 Comparar estas estaturas
      </a>
    </div>

    <!-- Navigation to other rankings -->
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-3">
      {otherRankings.slice(0, 6).map(r => (
        <a href={`/ranking/${r.slug}`}
          class="glass rounded-xl p-4 text-sm text-stone-400 hover:text-white transition-colors group">
          <p class="font-semibold group-hover:text-brand-400 transition-colors">{r.titulo}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
