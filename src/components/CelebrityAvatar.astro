---
interface Props {
  id: string;
  nombre: string;
  foto: string | null;
  color: string;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { id, nombre, foto, color, size = 'md', class: className = '' } = Astro.props;

const sizes = {
  sm: 'w-10 h-10',
  md: 'w-16 h-16',
  lg: 'w-24 h-24',
};

const initialSizes = {
  sm: 'text-xs',
  md: 'text-lg',
  lg: 'text-2xl',
};

const initials = nombre
  .split(' ')
  .slice(0, 2)
  .map(w => w[0])
  .join('')
  .toUpperCase();
---
<div class={`rounded-full overflow-hidden flex-shrink-0 ${sizes[size]} ${className}`}
  style={foto ? '' : `background: linear-gradient(135deg, ${color}55, ${color}22)`}>
  {foto ? (
    <img src={foto} alt={`Foto de ${nombre}`}
      class="w-full h-full object-cover"
      loading="lazy" decoding="async" />
  ) : (
    <div class="w-full h-full flex items-center justify-center">
      <span class={`font-bold ${initialSizes[size]} select-none`}
        style={`color: ${color}`}>{initials}</span>
    </div>
  )}
</div>
