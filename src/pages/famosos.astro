---
import Base from '../layouts/Base.astro';
import famososData from '../data/famosos.json';
import { cmToFtIn } from '../utils/height';

const sorted = [...famososData].sort((a, b) => b.estaturaCm - a.estaturaCm);

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Todos los famosos y sus estaturas",
  "description": "Directorio completo de famosos y celebridades con sus estaturas verificadas.",
  "numberOfItems": famososData.length,
  "itemListElement": sorted.slice(0, 10).map((f, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Person",
      "name": f.fullName || f.nombre,
      "height": { "@type": "QuantitativeValue", "value": f.estaturaCm, "unitCode": "CMT" },
    }
  })),
};

const categories = [
  { id: 'todos', label: 'Todos', emoji: '🌟' },
  { id: 'futbol', label: 'Fútbol', emoji: '⚽' },
  { id: 'musica', label: 'Música', emoji: '🎵' },
  { id: 'cine-tv', label: 'Cine & TV', emoji: '🎬' },
  { id: 'deportes', label: 'Deportes', emoji: '🏆' },
  { id: 'influencers', label: 'Streamers', emoji: '📱' },
];
---
<Base
  title="Todos los famosos y sus estaturas | Estaturas.com"
  description="Todos los famosos y sus estaturas. Busca y filtra por categoría: fútbol, música, cine, streamers y más."
  schema={schema}
>
  <div class="max-w-6xl mx-auto px-4 py-10">
    <nav class="text-sm text-stone-500 mb-6 flex items-center gap-2">
      <a href="/" class="hover:text-stone-300">Inicio</a>
      <span>›</span>
      <span class="text-stone-300">Famosos</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-2">
      Estaturas de famosos
    </h1>
    <p class="text-stone-400 mb-8">{famososData.length} famosos y contando. ¿Quién será el más alto? Spoiler: no es quien piensas 😏</p>

    <!-- Category filter tabs -->
    <div class="flex flex-wrap gap-2 mb-8" id="category-tabs">
      {categories.map(cat => (
        <button
          data-category={cat.id}
          class={`category-tab px-4 py-2 rounded-full text-sm font-medium transition-all cursor-pointer
            ${cat.id === 'todos' ? 'bg-brand-500 text-white' : 'glass text-stone-400 hover:text-white'}`}>
          {cat.emoji} {cat.label}
        </button>
      ))}
    </div>

    <!-- Card grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4" id="famosos-grid">
      {sorted.map(f => (
        <a href={`/${f.id}`}
          class="famoso-card glass rounded-2xl p-4 text-center group"
          data-category={f.categoria}
          style={`--glow: ${f.color}`}
          onmouseover={`this.style.boxShadow='0 0 20px ${f.color}33'; this.style.borderColor='${f.color}44'`}
          onmouseout={`this.style.boxShadow=''; this.style.borderColor=''`}>
          <!-- Photo/Avatar -->
          <div class="w-16 h-16 mx-auto mb-3 rounded-full overflow-hidden"
            style={f.foto ? '' : `background: linear-gradient(135deg, ${f.color}40, ${f.color}20)`}>
            {f.foto ? (
              <img src={f.foto} alt={f.nombre} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <svg viewBox="0 0 100 100" class="w-full h-full" aria-hidden="true">
                <circle cx="50" cy="35" r="18" fill={`${f.color}80`} />
                <ellipse cx="50" cy="85" rx="30" ry="22" fill={`${f.color}60`} />
              </svg>
            )}
          </div>
          <!-- Info -->
          <p class="text-white text-sm font-bold leading-tight mb-1 group-hover:text-brand-400 transition-colors">
            {f.nombre}
          </p>
          <p class="text-xs font-semibold" style={`color: ${f.color}`}>{f.estaturaCm}cm</p>
          <p class="text-stone-500 text-xs">{f.bandera} {f.profesion?.split('/')[0].trim()}</p>
        </a>
      ))}
    </div>

    <!-- No results message -->
    <p id="no-results" class="hidden text-center text-stone-500 py-12 text-lg">
      No hay famosos en esta categoría todavía 🤷
    </p>
  </div>

  <!-- Client-side category filtering -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.category-tab');
      const cards = document.querySelectorAll<HTMLElement>('#famosos-grid > a');
      const noResults = document.getElementById('no-results');

      function filterByCategory(cat: string) {
        tabs.forEach(t => {
          t.classList.remove('bg-brand-500', 'text-white');
          t.classList.add('text-stone-400');
          if (!t.classList.contains('glass')) t.classList.add('glass');
          if ((t as HTMLElement).dataset.category === cat) {
            t.classList.add('bg-brand-500', 'text-white');
            t.classList.remove('glass', 'text-stone-400');
          }
        });
        let visible = 0;
        cards.forEach(card => {
          if (cat === 'todos' || card.dataset.category === cat) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });
        if (noResults) noResults.classList.toggle('hidden', visible > 0);
      }

      // Auto-filter from URL param
      const urlCat = new URLSearchParams(window.location.search).get('cat');
      if (urlCat) filterByCategory(urlCat);

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const cat = (tab as HTMLElement).dataset.category!;
          filterByCategory(cat);
        });
      });
    });
  </script>
</Base>
